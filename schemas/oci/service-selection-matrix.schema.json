{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCI Service Selection Matrix",
  "type": "object",
  "required": [
    "capabilities"
  ],
  "properties": {
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "logicalCapability",
          "preferredService"
        ],
        "properties": {
          "logicalCapability": {
            "type": "string"
          },
          "preferredService": {
            "type": "string"
          },
          "alternativeService": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}