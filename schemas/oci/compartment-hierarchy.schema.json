{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCI Compartment Hierarchy",
  "type": "object",
  "required": [
    "tenancy",
    "compartments"
  ],
  "properties": {
    "tenancy": {
      "type": "string"
    },
    "compartments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "purpose"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "parent": {
            "type": "string"
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}