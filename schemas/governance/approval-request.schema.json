{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approval Request",
  "type": "object",
  "required": [
    "requestId",
    "requester",
    "decisionType"
  ],
  "properties": {
    "requestId": {
      "type": "string"
    },
    "requester": {
      "type": "string"
    },
    "decisionType": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "riskLevel": {
      "type": "string"
    }
  }
}
