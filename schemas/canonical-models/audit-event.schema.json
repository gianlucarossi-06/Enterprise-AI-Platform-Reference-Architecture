{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditEvent",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "actor",
    "runId"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventType": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object"
    },
    "runId": {
      "type": "string"
    },
    "details": {
      "type": "object"
    }
  }
}
