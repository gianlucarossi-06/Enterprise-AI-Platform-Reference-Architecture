{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/operations/runbook.schema.json",
  "title": "Runbook",
  "type": "object",
  "required": [
    "runbookId",
    "title",
    "service",
    "severity",
    "steps"
  ],
  "properties": {
    "runbookId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "service": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lastReviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  },
  "additionalProperties": false
}