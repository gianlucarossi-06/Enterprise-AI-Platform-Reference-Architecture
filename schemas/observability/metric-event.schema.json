{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Metric Event",
  "type": "object",
  "required": [
    "name",
    "value",
    "timestamp",
    "service"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "value": {
      "type": [
        "number",
        "integer"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "service": {
      "type": "string"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
