{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trace Envelope",
  "type": "object",
  "required": [
    "traceId",
    "spanId",
    "runId",
    "timestamp",
    "service"
  ],
  "properties": {
    "traceId": {
      "type": "string"
    },
    "spanId": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "service": {
      "type": "string"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
