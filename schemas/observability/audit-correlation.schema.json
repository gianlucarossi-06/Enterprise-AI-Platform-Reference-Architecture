{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Correlation",
  "type": "object",
  "required": [
    "eventId",
    "runId",
    "decisionId",
    "timestamp"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "decisionId": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "resource": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    }
  }
}
